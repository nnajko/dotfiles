[include]
    path = ~/.config/delta/themes/catppuccin.gitconfig
[user]
	email = niklas.b@vagabond.com
	name = Niklas Blomqvist
[credential]
	helper = 
	helper = /usr/sbin/git-credential-manager
	credentialStore = gpg
	guiPrompt = false
[credential "https://dev.azure.com"]
	useHttpPath = true
[core]
    pager = delta
    excludesFile = ~/.config/git/ignore
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    dark = true
    features = catppuccin-mocha
	side-by-side = true
	line-numbers = true
	hyperlinks = true
	blame-format = "{author:<15} {commit:<8} {timestamp:<15} "
[diff]
    algorithm = histogram
[merge]
    conflictStyle = zdiff3
